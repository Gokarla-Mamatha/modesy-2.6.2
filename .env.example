#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = production
# CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = https://desibazars.com/
app.debug = false  

#--------------------------------------------------------------------
# LICENSE
#--------------------------------------------------------------------
PURCHASE_CODE = your_purchase_code
LICENSE_KEY = your_license_key

#--------------------------------------------------------------------
# PAYMENT ICONS
#--------------------------------------------------------------------
PAYMENT_ICONS = visa,mastercard,maestro,amex,discover

#--------------------------------------------------------------------
# COOKIE
#--------------------------------------------------------------------  
cookie.prefix = 'mds_'
cookie.secure = true
cookie.httponly = true
cookie.samesite = Lax

#--------------------------------------------------------------------
# SECURITY
#--------------------------------------------------------------------
app.CSPEnabled = true

#--------------------------------------------------------------------
# TAXJAR
#--------------------------------------------------------------------
taxjar.apiKey=your_taxjar_api_key

#--------------------------------------------------------------------
# USPS ADDRESS VALIDATION (soft validation for US addresses)
# Get keys from https://developer.usps.com (create an app -> Consumer Key/Secret).
# Leave blank to disable; addresses are then saved exactly as entered.
#--------------------------------------------------------------------
usps.consumerKey=
usps.consumerSecret=
# usps.baseUrl = https://apis.usps.com          # production (default)
# usps.baseUrl = https://apis-tem.usps.com      # USPS test environment

#--------------------------------------------------------------------
# TWILIO
#--------------------------------------------------------------------
TWILIO_SID='your_twilio_account_sid'
TWILIO_TOKEN='your_twilio_auth_token'
TWILIO_FROM='your_twilio_phone_number'

#--------------------------------------------------------------------
# STRIPE
#--------------------------------------------------------------------
stripe.publishableKey = 'your_stripe_publishable_key'
stripe.secretKey = 'your_stripe_secret_key'